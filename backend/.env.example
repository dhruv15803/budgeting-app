# Copy to .env in this directory and adjust values.
# Run the API from backend/ (e.g. make run) so godotenv loads .env here.

PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/budgeting?sslmode=disable

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=24h

# Base URL used in verification links sent by email
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_TTL=48h

# SMTP (registration sends a verification email)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

# Recurring-expense generator cron (default: 00:05 UTC daily)
CRON_SCHEDULE=5 0 * * *

# Optional: comma-separated browser origins (defaults include localhost:5173 and :3001)
# CORS_ALLOWED_ORIGINS=http://localhost:5173
