# Copy to `.env` in the repository root (same folder as docker-compose.yml).
# Docker Compose loads `.env` automatically for variable substitution and defaults.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=budgeting

# Connection string for the API container (`postgres` is the Compose service hostname)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/budgeting?sslmode=disable

JWT_SECRET=replace-with-a-long-random-secret

JWT_EXPIRY=24h
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_TTL=48h

# Host-mapped ports (optional overrides)
API_PORT=3000
FRONTEND_PORT=5173

# Baked into the frontend image at build time — must match the host port you publish for the API.
# If `docker compose up` fails with "bind ... 3000", something else is using 3000; pick a free port and rebuild:
#   API_PORT=3001
#   VITE_API_URL=http://localhost:3001/api
VITE_API_URL=http://localhost:3000/api

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Bundled Mailpit service (Compose service name `mailpit`)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

CRON_SCHEDULE=5 0 * * *

# Google Sign-In (optional locally; for Docker you must set one of these in this file — frontend/.env is not copied into the image)
# GOOGLE_OAUTH_CLIENT_ID=your-id.apps.googleusercontent.com
# or the same value as:
# VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
